# Authentication
APP_PASSWORD_HASH=          # bcrypt hash of your password (use: npx bcryptjs hash "yourpassword")
SESSION_SECRET=             # Random 32+ char string (use: openssl rand -hex 32)

# Todoist
TODOIST_API_TOKEN=          # Get from: https://todoist.com/app/settings/integrations/developer

# LLM - Primary (Gemini Flash)
GEMINI_API_KEY=             # Get from: https://aistudio.google.com/apikey

# LLM - Heavy (Claude Opus)
ANTHROPIC_API_KEY=          # Get from: https://console.anthropic.com/

# Voice (Whisper)
OPENAI_API_KEY=             # Get from: https://platform.openai.com/api-keys

# Database (Turso)
TURSO_DATABASE_URL=         # Get from: turso db show burn-down-engine --url
TURSO_AUTH_TOKEN=           # Get from: turso db tokens create burn-down-engine
